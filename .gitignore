# Third-party OSS code under test lives on disk in these dirs (each is a
# git clone with its own history; their `rex-wt-*` branches preserve
# every run's generated test content). They contain venvs, __pycache__,
# and other artifacts we don't want in our bench-root history.
#
# To inspect a Run-1 worktree's content:  cd itsdangerous/wt-iter2 && git log
# To regenerate from scratch:               see CHANGELOG + the run-1.md inventory
/itsdangerous/
/httpx/
/requests/

# Python + tooling artifacts (in case any leak into the root)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor / OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Coverage / verification scratch files
/tmp_*

# Don't track the aggregator's local result dump — it's regenerated by
# the script and the committed reports/README.md is the canonical version.
/results.json
